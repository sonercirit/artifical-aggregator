{
  "name": "artificial-aggregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:apply:local": "wrangler d1 migrations apply artificial-aggregator --local",
    "db:apply:remote": "wrangler d1 migrations apply artificial-aggregator --remote",
    "cf:d1:create": "wrangler d1 create artificial-aggregator",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "drizzle-orm": "^0.39.0",
    "hono": "^4.6.16"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/node": "^25.6.2",
    "drizzle-kit": "^0.30.2",
    "prettier": "^3.8.3",
    "typescript": "^5.7.3",
    "wrangler": "^4.90.0"
  }
}
